+    /// <summary>
+    /// Sends an initiator-initiated NOP-Out with ITT=0xFFFFFFFF and TTT=0xFFFFFFFF.
+    /// This is a "ping" that keeps the iSCSI session alive without requiring a response.
+    /// </summary>
